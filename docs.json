        "groups": [
          {
            "group": "Core workflows",
            "pages": [
              "product/reports",
              "product/incidents",
              "product/vehicles",
              "product/feedback",
              "product/search"
            ]
          },
          {
            "group": "Network and operations",
            "pages": [
              "product/network",
              "product/surveyor",
              "product/learning"
            ]
          }
        ]
      },
      {
        "tab": "Repositories",
        "groups": [
          {
            "group": "Repo guides",
            "pages": [
