        "groups": [
          {
            "group": "Current implementation",
            "pages": [
              "api-reference/introduction",
              "api-reference/live-interfaces",
              "api-reference/public-app-routes",
              "api-reference/restricted-operations-routes",
              "api-reference/learning-and-auth",
