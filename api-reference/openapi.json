{
  "openapi": "3.1.0",
  "info": {
    "title": "TIBS Future Public API Draft",
    "description": "Draft external API skeleton derived from the current TIBS repo set and domain mapping notes. This file does not describe the live Next.js route handlers in tibs or tibs-survey; those are documented in the MDX pages under api-reference.",
    "version": "0.3.0-draft"
  },
  "servers": [
    {
      "url": "https://api.tibs.example",
      "description": "Placeholder origin for a future dedicated API, not a live production server"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    { "name": "Reports" },
    { "name": "Incidents" },
    { "name": "Vehicles" },
    { "name": "Feedback" },
    { "name": "Network" },
    { "name": "Surveyor" },
    { "name": "Learning" },
    { "name": "Search" },
    { "name": "Admin" }
  ],
  "paths": {
    "/reports": {
      "post": {
        "tags": ["Reports"],
        "summary": "Submit a raw incident report",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Report accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ReportSubmission"
                }
              }
            }
          }
        }
      }
    },
    "/incidents/nearby": {
      "get": {
        "tags": ["Incidents"],
        "summary": "List incidents near a location",
        "parameters": [
          {
            "name": "lat",
            "in": "query",
            "required": true,
            "schema": { "type": "number" }
          },
          {
            "name": "lng",
            "in": "query",
            "required": true,
            "schema": { "type": "number" }
          },
          {
            "name": "corridor",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "window_hours",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "Nearby incidents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IncidentSummary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/incidents/{id}": {
      "get": {
        "tags": ["Incidents"],
        "summary": "Get incident detail",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Incident detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IncidentDetail"
                }
              }
            }
          }
        }
      }
    },
    "/vehicles/{plate}": {
      "get": {
        "tags": ["Vehicles"],
        "summary": "Get a public vehicle profile by plate",
        "parameters": [
          {
            "name": "plate",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Vehicle profile",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/VehicleProfile"
                }
              }
            }
          }
        }
      }
    },
    "/vehicles/{id}/incidents": {
      "get": {
        "tags": ["Vehicles"],
        "summary": "List recent incidents for a vehicle",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Vehicle incidents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IncidentSummary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/feedback": {
      "post": {
        "tags": ["Feedback"],
        "summary": "Submit ride feedback",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FeedbackInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feedback accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedbackSubmission"
                }
              }
            }
          }
        }
      }
    },
    "/vehicles/{id}/feedback-summary": {
      "get": {
        "tags": ["Feedback"],
        "summary": "Get public feedback summary for a vehicle",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Feedback summary",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeedbackSummary"
                }
              }
            }
          }
        }
      }
    },
    "/corridors": {
      "get": {
        "tags": ["Network"],
        "summary": "List supported corridors",
        "responses": {
          "200": {
            "description": "Corridors",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Corridor"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/corridors/{id}/incidents": {
      "get": {
        "tags": ["Network"],
        "summary": "List incidents for a corridor",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Corridor incidents",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/IncidentSummary"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/routes": {
      "get": {
        "tags": ["Network"],
        "summary": "List routes",
        "responses": {
          "200": {
            "description": "Routes",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Route"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/saccos": {
      "get": {
        "tags": ["Network"],
        "summary": "List saccos",
        "responses": {
          "200": {
            "description": "Saccos",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Sacco"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/saccos/{id}/vehicles": {
      "get": {
        "tags": ["Network"],
        "summary": "List vehicles assigned to a sacco",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Sacco vehicles",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/VehicleProfile"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/surveyor/session/start": {
      "post": {
        "tags": ["Surveyor"],
        "summary": "Start a surveyor session",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SurveyorSessionStart"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Surveyor session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SurveyorSession"
                }
              }
            }
          }
        }
      }
    },
    "/surveyor/assignments": {
      "get": {
        "tags": ["Surveyor"],
        "summary": "List surveyor assignments",
        "responses": {
          "200": {
            "description": "Assignments",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Assignment"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/surveyor/stats": {
      "get": {
        "tags": ["Surveyor"],
        "summary": "Get surveyor operational stats",
        "responses": {
          "200": {
            "description": "Surveyor stats",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SurveyorStats"
                }
              }
            }
          }
        }
      }
    },
    "/learning/courses": {
      "get": {
        "tags": ["Learning"],
        "summary": "List learning courses",
        "responses": {
          "200": {
            "description": "Learning courses",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/LearningCourse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/learning/progress": {
      "get": {
        "tags": ["Learning"],
        "summary": "Get learning progress",
        "responses": {
          "200": {
            "description": "Learning progress",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LearningProgress"
                }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "tags": ["Search"],
        "summary": "Search across vehicles, saccos, and routes",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Mixed search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SearchResult"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/review-queue": {
      "get": {
        "tags": ["Admin"],
        "summary": "List restricted review queue items",
        "responses": {
          "200": {
            "description": "Review queue",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AdminReviewItem"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/admin/review": {
      "post": {
        "tags": ["Admin"],
        "summary": "Submit an admin review decision",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AdminReviewDecision"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Review decision accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Message"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Message": {
        "type": "object",
        "properties": {
          "message": { "type": "string" }
        }
      },
      "ReportInput": {
        "type": "object",
        "properties": {
          "plate": { "type": "string" },
          "route": { "type": "string" },
          "sacco": { "type": "string" },
          "category": { "type": "string" },
          "notes": { "type": "string" },
          "lat": { "type": "number" },
          "lng": { "type": "number" }
        }
      },
      "ReportSubmission": {
        "type": "object",
        "properties": {
          "report_id": { "type": "string" },
          "status": { "type": "string", "example": "accepted" }
        }
      },
      "IncidentSummary": {
        "type": "object",
        "properties": {
          "incident_id": { "type": "string" },
          "type": { "type": "string" },
          "severity": { "type": "string" },
          "confidence": { "type": "number" }
        }
      },
      "IncidentDetail": {
        "type": "object",
        "properties": {
          "incident_id": { "type": "string" },
          "reports": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/ReportSubmission" }
          },
          "media": {
            "type": "array",
            "items": { "type": "string" }
          },
          "confidence": { "type": "number" }
        }
      },
      "VehicleProfile": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "plate": { "type": "string" },
          "sacco": { "type": "string" },
          "route": { "type": "string" },
          "risk_score": { "type": "number" },
          "incident_count": { "type": "integer" }
        }
      },
      "FeedbackInput": {
        "type": "object",
        "properties": {
          "vehicle_id": { "type": "string" },
          "sentiment": { "type": "string" },
          "tags": {
            "type": "array",
            "items": { "type": "string" }
          },
          "notes": { "type": "string" }
        }
      },
      "FeedbackSubmission": {
        "type": "object",
        "properties": {
          "feedback_id": { "type": "string" },
          "status": { "type": "string", "example": "accepted" }
        }
      },
      "FeedbackSummary": {
        "type": "object",
        "properties": {
          "vehicle_id": { "type": "string" },
          "sentiment_score": { "type": "number" },
          "common_tags": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      },
      "Corridor": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "risk_score": { "type": "number" }
        }
      },
      "Route": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "corridor": { "type": "string" }
        }
      },
      "Sacco": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "score": { "type": "number" }
        }
      },
      "SurveyorSessionStart": {
        "type": "object",
        "properties": {
          "project_id": { "type": "string" },
          "started_at": { "type": "string", "format": "date-time" }
        }
      },
      "SurveyorSession": {
        "type": "object",
        "properties": {
          "session_id": { "type": "string" },
          "status": { "type": "string" }
        }
      },
      "Assignment": {
        "type": "object",
        "properties": {
          "assignment_id": { "type": "string" },
          "route": { "type": "string" },
          "slot": { "type": "string" }
        }
      },
      "SurveyorStats": {
        "type": "object",
        "properties": {
          "completed_assignments": { "type": "integer" },
          "submissions": { "type": "integer" },
          "active_hours": { "type": "number" }
        }
      },
      "LearningCourse": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "slug": { "type": "string" },
          "title": { "type": "string" }
        }
      },
      "LearningProgress": {
        "type": "object",
        "properties": {
          "course_id": { "type": "string" },
          "completed_modules": { "type": "integer" },
          "completion_percent": { "type": "number" }
        }
      },
      "SearchResult": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "id": { "type": "string" },
          "label": { "type": "string" }
        }
      },
      "AdminReviewItem": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "status": { "type": "string" },
          "reason": { "type": "string" }
        }
      },
      "AdminReviewDecision": {
        "type": "object",
        "properties": {
          "item_id": { "type": "string" },
          "decision": { "type": "string" },
          "notes": { "type": "string" }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "error",
          "message"
        ],
        "properties": {
          "error": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
